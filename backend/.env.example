# Option 1: connection string (used by docker-compose / cloud platforms)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/inventory_db

# Option 2: individual vars (used for local development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=inventory_db

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MinIO / Object Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=inventory-files
# Public base URL for stored files, accessible from the browser.
# In Docker Compose (with nginx proxy), set to /storage
# For standalone MinIO exposed on a public domain, set to https://storage.example.com
MINIO_PUBLIC_BASE_URL=/storage
# Public-facing MinIO URL used to generate browser-accessible presigned URLs.
# The MinIO SDK signs URLs with the configured endpoint as the host, so this must
# match the address the browser uses to reach MinIO directly.
# In Docker Compose, MinIO port 9000 is mapped to the host: http://localhost:9000
# In production, set to your public MinIO URL: https://storage.example.com
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
