# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/database

# Auth
JWT_SECRET=change-this-in-production-super-secret
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=inventory-files

# Public base URL for MinIO objects served to the browser.
# In Docker Compose this is handled by the nginx /storage/ proxy so use "/storage".
# In local dev (no nginx), leave unset — images are served directly from MinIO on MINIO_PORT.
# MINIO_PUBLIC_BASE_URL=/storage
